# Base URL of the Express API. The typed fetch client prefixes this and always
# sends credentials so the httpOnly auth cookie travels with every request.
NEXT_PUBLIC_API_URL=http://localhost:4000

# Optional ambient background photo (the "real room behind frosted glass" look).
# Drop a photo at website/public/background.jpg and set this to /background.jpg,
# or point it at any image URL. Leave unset to use the warm CSS ambient default.
# NEXT_PUBLIC_BG_IMAGE=/background.jpg
