# ───────────────────────────────────────────────
# Server configuration
# ───────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# Client origin — used by CORS (credentials: true). Must match the running client exactly.
CLIENT_URL=http://localhost:3000

# ───────────────────────────────────────────────
# MongoDB
# ───────────────────────────────────────────────
MONGODB_URI=mongodb://127.0.0.1:27017/office_management
MONGODB_DB=office_management

# ───────────────────────────────────────────────
# Auth
# ───────────────────────────────────────────────
# Use a long random string in production (e.g. `openssl rand -hex 48`)
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-chars
JWT_EXPIRES_IN=7d
# Cookie sameSite: "lax" for same-site local dev; use "none" (with secure+HTTPS) for cross-site deploys.
COOKIE_SAMESITE=lax
COOKIE_SECURE=false

# ───────────────────────────────────────────────
# Company / timezone (used for day boundaries & reports)
# ───────────────────────────────────────────────
COMPANY_TZ=Asia/Kolkata

# ───────────────────────────────────────────────
# Optional SMTP (password-reset emails — later phases)
# ───────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Office Management <no-reply@example.com>"
